# CovenantOps Agent configuration

# Frontend origin(s) for CORS
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:5173

# Real credit-agreement PDF the agent grounds on
COVENANTOPS_AGREEMENT_PDF=data/credit_agreement.pdf

# Receipt signing key (base64 Ed25519). RECOMMENDED for any real deployment:
# without it, a key is generated per instance and receipts won't verify across
# restarts or multiple replicas. Generate a stable one with:
#   python -c "from app.trust.receipt import ReceiptService; print(ReceiptService.generate_key_b64())"
# COVENANTOPS_SIGNING_KEY_B64=

# --- Governance (OPTIONAL) ---
# If unset, the agent uses the local fallback guard (fully functional, fail-safe).
# AIRG_URL=https://api.airg.nov-tia.com
# AIRG_API_KEY=
AIRG_TIMEOUT_SECONDS=4

# --- Vultr Serverless Inference (OPTIONAL — required to score on the Vultr track) ---
# If unset, the agent runs deterministic local reasoning/retrieval (demo-safe).
# All LLM/RAG workloads route to Vultr Serverless Inference (no GPU needed).
# VULTR_INFERENCE_API_KEY=
# Reasoning model served by Vultr Serverless Inference:
VULTR_CHAT_MODEL=kimi-k2-instruct
# For document grounding / retrieval, use a VultronRetriever model via Serverless
# Inference: https://huggingface.co/collections/vultr/vultronretriever
VULTR_TIMEOUT_SECONDS=20

